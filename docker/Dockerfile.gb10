# nvllm -- vLLM for DGX Spark (GB10, SM120)
# Build: docker build -f docker/Dockerfile.gb10 -t nvllm:gb10 .
#
# This image builds vLLM from the nvllm fork (already patched -- no cherry-picks
# or patch scripts needed). Target hardware: NVIDIA DGX Spark / GB10 (SM120).
#
# PyTorch: nightly cu132 pinned 2026-04-02
# CUDA:    13.2 (devel base)
# Arch:    SM120 only (keeps build fast)

FROM nvidia/cuda:13.2.0-devel-ubuntu24.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive

# -- System build dependencies --
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3.12 python3.12-dev python3.12-venv python3-pip \
        git wget curl ccache \
        build-essential cmake ninja-build \
        libssl-dev libffi-dev \
    && rm -rf /var/lib/apt/lists/*

# -- Python venv --
RUN python3.12 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
ENV VIRTUAL_ENV="/opt/venv"

# -- CUDA env --
ENV CUDA_HOME="/usr/local/cuda"
ENV PATH="${CUDA_HOME}/bin:${PATH}"
ENV LD_LIBRARY_PATH="${CUDA_HOME}/lib64:${LD_LIBRARY_PATH}"

# -- PyTorch nightly cu132 (pinned) --
RUN pip install --no-cache-dir \
    torch==2.12.0.dev20260402+cu132 \
    torchvision==0.27.0.dev20260402+cu132 \
    torchaudio==2.11.0.dev20260402+cu132 \
    --index-url https://download.pytorch.org/whl/nightly/cu132

# -- vLLM build dependencies --
RUN pip install --no-cache-dir \
    "cmake>=3.26.1" ninja "packaging>=24.2" \
    "setuptools>=77.0.3,<81.0.0" "setuptools-scm>=8" \
    wheel "jinja2>=3.1.6" regex build \
    "protobuf>=5.29.6" "grpcio-tools==1.78.0"

# -- Copy nvllm source (fork is already patched -- no cherry-picks needed) --
COPY . /app/nvllm

# -- Build vLLM C++/CUDA extensions --
# Target SM120 (GB10 Blackwell) only -- keeps build time sane
ENV TORCH_CUDA_ARCH_LIST="12.0"
ENV VLLM_TARGET_DEVICE=cuda
ENV MAX_JOBS=4
ENV CCACHE_DIR=/tmp/ccache

WORKDIR /app/nvllm

# Constraint file: lock torch to our nightly cu132 so no dep can clobber it
RUN echo "torch==2.12.0.dev20260402+cu132" > /tmp/constraints.txt \
    && echo "torchvision==0.27.0.dev20260402+cu132" >> /tmp/constraints.txt \
    && echo "torchaudio==2.11.0.dev20260402+cu132" >> /tmp/constraints.txt
ENV PIP_CONSTRAINT=/tmp/constraints.txt

# Install requirements (torch is pinned by constraint, won't be replaced)
RUN pip install --no-cache-dir -r requirements/build.txt \
    && pip install --no-cache-dir -r requirements/common.txt \
       --index-url https://download.pytorch.org/whl/nightly/cu132 \
       --extra-index-url https://pypi.org/simple/ \
    && pip install --no-cache-dir \
       numba==0.61.2 "ray[cgraph]>=2.48.0" \
    || true

# Build + install vLLM (editable so patches land in-place)
RUN --mount=type=cache,target=/tmp/ccache \
    pip install --no-build-isolation --no-deps -e . 2>&1 | tail -80

# -- Triton (nightly, must match torch nightly's requirement) --
RUN pip install --no-cache-dir triton \
    --index-url https://download.pytorch.org/whl/nightly/cu132 \
    --extra-index-url https://pypi.org/simple/ \
    || pip install --no-cache-dir triton==3.6.0

# -- Runtime NVIDIA libs --
RUN pip install --no-cache-dir \
    nvidia-cutlass-dsl==4.4.0 \
    nvidia-cutlass-dsl-libs-base==4.4.0 \
    || true

# -- FlashInfer --
RUN pip install --no-cache-dir flashinfer-python==0.6.3 \
    || pip install --no-cache-dir flashinfer-python \
    || echo "WARN: flashinfer install failed -- will need manual install"

# -- Additional runtime deps --
RUN pip install --no-cache-dir --no-deps compressed-tensors==0.13.0
RUN pip install --no-cache-dir \
    scipy \
    numba==0.61.2 \
    "ray[cgraph]>=2.48.0" \
    || true
RUN pip install --no-cache-dir \
    "transformers @ git+https://github.com/huggingface/transformers.git" \
    "tokenizers>=0.21.1" \
    depyf==0.20.0 \
    pydantic loguru safetensors huggingface-hub

# -- Remaining vLLM runtime deps --
RUN pip install --no-cache-dir --no-deps \
    flashinfer-python==0.6.3 || true
RUN pip install --no-cache-dir \
    aiohttp "fastapi[standard]>=0.115.0" "openai>=1.99.1" \
    "prometheus_client>=0.18.0" "prometheus-fastapi-instrumentator>=7.0.0" \
    "tiktoken>=0.6.0" "lm-format-enforcer==0.11.3" "outlines_core==0.2.11" \
    "diskcache==5.6.3" "lark==1.2.2" "xgrammar==0.1.29" \
    "pillow" "opencv-python-headless>=4.13.0" \
    "mistral_common[image]>=1.9.1" "gguf>=0.17.0" \
    psutil py-cpuinfo sentencepiece setproctitle "six>=1.16.0" \
    blake3 cachetools cbor2 cloudpickle partial-json-parser \
    pybase64 python-json-logger "pyzmq>=25.0.0" watchfiles \
    msgspec msgpack jsonschema \
    "openai-harmony>=0.0.3" "anthropic>=0.71.0" \
    "model-hosting-container-standards>=0.1.13,<1.0.0" \
    "llguidance>=1.3.0,<1.4.0" mcp grpcio grpcio-reflection \
    ijson llvmlite \
    || true

# -- Templates --
COPY templates/nemotron_no_think.jinja /templates/nemotron_no_think.jinja

ENTRYPOINT ["python3", "-m", "vllm.entrypoints.cli.main"]
